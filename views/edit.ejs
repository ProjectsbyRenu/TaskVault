<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="form text-white py-10 px-5">
        <form action="/edit" method="post">

        <input name="previous" readonly class="block w-full rounded-md  px-5 py-2 mb-2 bg-zinc-900 text-gray-400" type="text" value=<%=filename %>>

         <input name="new" class="block w-full rounded-md  px-5 py-2 bg-zinc-900 " type="text" placeholder="new name">


        <input class="px-5 py-2 rounded-md mt-5 bg-yellow-600 " type="submit" value="update name">
    </div>
</body>
</html>