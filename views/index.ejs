<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
   <div class="main w-full min-h-screen bg-black">
    <div class="form text-white py-10 px-5">
        <form action="/create" method="post">

        <input name="title" class="block w-full rounded-md  px-5 py-2 bg-zinc-900 " type="text" placeholder="title here" required>

        <textarea name="tasks" class="block w-full rounded-md  px-5 py-2 mt-2 resize-none bg-zinc-900" name="" id="" placeholder="you can add tasks here" ></textarea>

        <input class="px-5 py-2 rounded-md mt-5 bg-blue-600 " type="submit" value="create tasks">
    </div>
      <div class="tasks py-10 px-5 flex gap-4">
      <% if(files.length>0){ %>
        <% files.forEach((val) => {%>
            <div class="task min-w-72 px-3 py-2 rounded-md bg-zinc-900">
            <h1 class="bg-zinc-900 text-white  text-2xl tracking-tighter"><%= val  %></h1>
          <a href="/file/<%=val%>" class="text-blue-500">read more...</a>
        </div>    
        <% }); %>
        <% } else{ %>
            <h3 class="text-white bg-zinc-900 px-3 py-2">no tasks yet</h3>
            <% } %>

       


       
      
         <div class="task hidden w-72 px-3 py-2 rounded-md bg-zinc-900">
            <h1 class="bg-zinc-900 text-white  text-2xl tracking-tighter">some tasks goes here</h1>
        </div>
       </form>
      </div>
   </div>
</body>
</html>